{
  "dependencies": {
    "@types/node": "^25.3.3",
    "length-prefixed-stream": "^1.6.0",
    "mediasoup": "^3.13.13",
    "minimist": "^1.2.8",
    "p-queue": "^8.0.1",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "typedoc": "^0.25.13",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "ingress": "tsx server.ts --mode=ingress",
    "ingress:watch": "tsx watch server.ts --mode=ingress",
    "egress": "tsx server.ts --mode=egress",
    "egress:watch": "tsx watch server.ts --mode=egress",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "docs": "typedoc --options typedoc.json",
    "typecheck": "tsc --noEmit",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "lint": "eslint server.ts lib/*.ts",
    "lint:fix": "eslint server.ts lib/*.ts --fix"
  },
  "name": "media-relay",
  "version": "0.1.0-alpha.1",
  "description": "Remotely instructable SFU powered by mediasoup and netsockets",
  "main": "server.js",
  "directories": {
    "lib": "lib"
  },
  "author": "techtruth@gmail.com",
  "license": "ISC",
  "type": "module",
  "exports": "/dist/index.js"
}
