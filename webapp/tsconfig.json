{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "types/*": ["../types/*"]
    },
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2020"],
    "types": ["node"],
    "skipLibCheck": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["lib/**/*.ts", "../types/**/*.d.ts"]
}
