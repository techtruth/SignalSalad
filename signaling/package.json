{
  "dependencies": {
    "express": "^5.2.1",
    "length-prefixed-stream": "^2.0.0",
    "mediasoup": "^3.19.17",
    "pem": "^1.14.8",
    "tsx": "^4.21.0",
    "uuid4": "^2.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-mermaid": "^1.12.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "docs": "typedoc --options typedoc.json",
    "test": "npm run test:integration",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:integration": "tsx --test tests/integration/*.test.ts",
    "test:full": "node --test tests/full/*.test.js",
    "test:peer": "npm run test:integration",
    "test:runtime": "npm run test:full",
    "test:all": "npm run test:integration && npm run test:full",
    "typecheck": "tsc --noEmit",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "lint": "eslint server.ts \"lib/**/*.ts\"",
    "lint:fix": "eslint server.ts \"lib/**/*.ts\" --fix"
  },
  "name": "signaling",
  "type": "module",
  "version": "0.1.0-alpha.1",
  "description": "Coordination server for directing media streams. Accepts incoming connections from media servers with netsocket, and client browsers with websocket.",
  "main": "server.js",
  "author": "techtruth@gmail.com",
  "license": "ISC"
}
